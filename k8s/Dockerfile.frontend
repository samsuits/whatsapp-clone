# ---------- Build Stage ----------
FROM node:20-alpine AS build

WORKDIR /app

# Copy package files first (better layer caching)
COPY frontend/package*.json ./
RUN npm install

# Copy rest of frontend source
COPY frontend/ ./
RUN npm run build

# ---------- Production Stage ----------
FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]